@model CatalogoWeb.Entities.Contenido

@{
    ViewData["Title"] = Model.Titulo;
    var esSerie = Model is CatalogoWeb.Entities.Serie;
    var serie = Model as CatalogoWeb.Entities.Serie;
}

@functions {
    string FondoUrl(CatalogoWeb.Entities.Contenido item)
    {
        return $"https://picsum.photos/seed/fondo{item.Id}/1800/900";
    }

    string PosterUrl(CatalogoWeb.Entities.Contenido item)
    {
        return $"https://picsum.photos/seed/poster{item.Id}/500/750";
    }

    string Estrellas(int calificacion)
    {
        if (calificacion < 1) calificacion = 1;
        if (calificacion > 5) calificacion = 5;

        return new string('★', calificacion) + new string('☆', 5 - calificacion);
    }
}

<style>
    body {
        background: #020617;
        color: #ffffff;
    }

    .detail-page {
        min-height: 100vh;
        background: #020617;
        padding-bottom: 60px;
    }

    .detail-hero {
        position: relative;
        min-height: 720px;
        background-size: cover;
        background-position: center;
        overflow: hidden;
    }

    .detail-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(2,6,23,0.98) 0%, rgba(2,6,23,0.82) 38%, rgba(2,6,23,0.38) 70%, rgba(2,6,23,0.20) 100%),
                    linear-gradient(0deg, #020617 0%, rgba(2,6,23,0.20) 50%, rgba(2,6,23,0.25) 100%);
    }

    .detail-content {
        position: relative;
        z-index: 2;
        width: min(1350px, 92%);
        margin: auto;
        padding-top: 85px;
        display: grid;
        grid-template-columns: 310px 1fr;
        gap: 38px;
        align-items: end;
    }

    .poster-box {
        border-radius: 26px;
        overflow: hidden;
        height: 465px;
        background-size: cover;
        background-position: center;
        box-shadow: 0 30px 70px rgba(0,0,0,0.65);
        border: 1px solid rgba(255,255,255,0.12);
    }

    .info-box {
        max-width: 850px;
        padding-bottom: 20px;
    }

    .brand {
        color: #93c5fd;
        font-weight: 900;
        letter-spacing: 3px;
        font-size: 15px;
        margin-bottom: 14px;
    }

    .detail-title {
        font-size: 64px;
        font-weight: 950;
        line-height: 1;
        margin-bottom: 18px;
    }

    .meta-line {
        color: #dbeafe;
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 14px;
    }

    .rating {
        color: #facc15;
        font-size: 18px;
        letter-spacing: 2px;
        margin-bottom: 18px;
    }

    .review {
        color: #cbd5e1;
        font-size: 18px;
        line-height: 1.7;
        max-width: 760px;
        margin-bottom: 25px;
    }

    .actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .stream-btn {
        border: none;
        border-radius: 999px;
        padding: 12px 24px;
        font-weight: 800;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

    .stream-btn:hover {
        transform: translateY(-2px);
    }

    .btn-primary-stream {
        background: #2563eb;
        color: white;
    }

    .btn-primary-stream:hover {
        background: #1d4ed8;
        color: white;
    }

    .btn-success-stream {
        background: #16a34a;
        color: white;
    }

    .btn-success-stream:hover {
        background: #15803d;
        color: white;
    }

    .btn-warning-stream {
        background: #f59e0b;
        color: #111827;
    }

    .btn-warning-stream:hover {
        background: #d97706;
        color: #111827;
    }

    .btn-danger-stream {
        background: #dc2626;
        color: white;
    }

    .btn-danger-stream:hover {
        background: #b91c1c;
        color: white;
    }

    .btn-light-stream {
        background: rgba(255,255,255,0.14);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,0.22);
    }

    .btn-light-stream:hover {
        background: rgba(255,255,255,0.24);
        color: #ffffff;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.75);
        border: 1px solid rgba(255,255,255,0.16);
        font-weight: 900;
        margin-bottom: 16px;
    }

    .status-vista {
        color: #4ade80;
    }

    .status-pendiente {
        color: #fbbf24;
    }

    .registro-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(37, 99, 235, 0.14);
        border: 1px solid rgba(147, 197, 253, 0.26);
        color: #bfdbfe;
        font-weight: 900;
        margin-bottom: 16px;
        margin-left: 8px;
    }

    .detail-lower {
        width: min(1350px, 92%);
        margin: -40px auto 0 auto;
        position: relative;
        z-index: 3;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 24px;
    }

    .glass-card {
        background: rgba(15, 23, 42, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 26px;
        padding: 26px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.35);
        backdrop-filter: blur(12px);
    }

    .glass-card h3 {
        font-weight: 900;
        margin-bottom: 18px;
        color: white;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .detail-item {
        background: #020617;
        border: 1px solid #1e293b;
        border-radius: 18px;
        padding: 16px;
    }

    .detail-label {
        color: #94a3b8;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .detail-value {
        color: white;
        font-size: 17px;
        font-weight: 850;
    }

    .mini-note {
        color: #94a3b8;
        line-height: 1.7;
    }

    @@media (max-width: 900px) {
        .detail-content {
            grid-template-columns: 1fr;
            padding-top: 40px;
        }

        .poster-box {
            width: 230px;
            height: 345px;
        }

        .detail-title {
            font-size: 42px;
        }

        .detail-lower {
            grid-template-columns: 1fr;
            margin-top: 20px;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }

        .registro-badge {
            margin-left: 0;
            margin-top: 8px;
        }
    }
</style>

<div class="detail-page">

    <section class="detail-hero" style="background-image: url('@FondoUrl(Model)');">
        <div class="detail-content">

            <div class="poster-box" style="background-image: url('@PosterUrl(Model)');"></div>

            <div class="info-box">
                <div class="brand">CINEPHILE</div>

                <span class="status-badge @(Model.Estado == "Vista" ? "status-vista" : "status-pendiente")">
                    @Model.Estado
                </span>

                @if (Model.EsAgregadoPorUsuario)
                {
                    <span class="registro-badge">Registrada</span>
                }
                else
                {
                    <span class="registro-badge">Sin registro</span>
                }

                <h1 class="detail-title">@Model.Titulo</h1>

                <div class="meta-line">
                    @Model.Tipo • @Model.Genero • @Model.Anio_estreno • @Model.Plataforma
                </div>

                <div class="rating">
                    @Estrellas(Model.Calificacion)
                </div>

                <p class="review">
                    @Model.Resenia
                </p>

                <div class="actions">
                    @if (Model.Estado == "Pendiente")
                    {
                        <a asp-action="MarcarVisto" asp-route-id="@Model.Id" class="stream-btn btn-success-stream">Marcar como vista</a>
                    }
                    else
                    {
                        <a asp-action="MarcarPendiente" asp-route-id="@Model.Id" class="stream-btn btn-warning-stream">Marcar como pendiente</a>
                    }

                    @if (Model.EsAgregadoPorUsuario)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="stream-btn btn-primary-stream">Editar registro</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="stream-btn btn-danger-stream">Quitar de registros</a>
                    }
                    else
                    {
                        <a asp-action="AgregarRegistro" asp-route-id="@Model.Id" class="stream-btn btn-primary-stream">Agregar registro</a>
                    }

                    <a asp-action="Registros" class="stream-btn btn-light-stream">Ver todos los registros</a>
                    <a asp-action="Index" class="stream-btn btn-light-stream">Volver al catálogo</a>
                </div>
            </div>

        </div>
    </section>

    <section class="detail-lower">

        <div class="glass-card">
            <h3>Reseña</h3>
            <p class="mini-note">@Model.Resenia</p>
        </div>

        <div class="glass-card">
            <h3>Detalles del contenido</h3>

            <div class="detail-grid">
                <div class="detail-item">
                    <div class="detail-label">Tipo</div>
                    <div class="detail-value">@Model.Tipo</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Género</div>
                    <div class="detail-value">@Model.Genero</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Año</div>
                    <div class="detail-value">@Model.Anio_estreno</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Plataforma</div>
                    <div class="detail-value">@Model.Plataforma</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Estado</div>
                    <div class="detail-value">@Model.Estado</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Registro</div>
                    <div class="detail-value">@(Model.EsAgregadoPorUsuario ? "Registrada" : "Sin registro")</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Calificación</div>
                    <div class="detail-value">@Model.Calificacion / 5</div>
                </div>

                @if (esSerie && serie != null)
                {
                    <div class="detail-item">
                        <div class="detail-label">Temporadas</div>
                        <div class="detail-value">@serie.Temporadas</div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-label">Episodios</div>
                        <div class="detail-value">@serie.Episodios</div>
                    </div>
                }
            </div>
        </div>

    </section>

</div>