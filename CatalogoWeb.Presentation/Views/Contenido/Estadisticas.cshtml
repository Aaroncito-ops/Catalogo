@{
    ViewData["Title"] = "Estadísticas";
    var top5 = ViewBag.Top5 as List<CatalogoWeb.Entities.Contenido>;
}

@functions {
    string Estrellas(int calificacion)
    {
        if (calificacion < 1) calificacion = 1;
        if (calificacion > 5) calificacion = 5;

        return new string('★', calificacion) + new string('☆', 5 - calificacion);
    }

    string PosterUrl(CatalogoWeb.Entities.Contenido item)
    {
        return $"https://picsum.photos/seed/stats{Uri.EscapeDataString(item.Titulo + item.Id)}/500/750";
    }
}

<style>
    body {
        background: #020617;
        color: #ffffff;
    }

    .stats-page {
        min-height: 100vh;
        padding: 55px 0 75px 0;
        background:
            radial-gradient(circle at top left, rgba(37,99,235,0.28), transparent 34%),
            radial-gradient(circle at top right, rgba(124,58,237,0.18), transparent 30%),
            #020617;
    }

    .stats-container {
        width: min(1350px, 94%);
        margin: auto;
    }

    .stats-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 32px;
    }

    .stats-header h1 {
        font-size: 44px;
        font-weight: 950;
        margin-bottom: 8px;
    }

    .stats-header p {
        color: #94a3b8;
        margin: 0;
        font-size: 16px;
    }

    .stream-btn {
        border: none;
        border-radius: 999px;
        padding: 11px 22px;
        font-weight: 800;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

    .stream-btn:hover {
        transform: translateY(-2px);
    }

    .btn-primary-stream {
        background: #2563eb;
        color: white;
    }

    .btn-primary-stream:hover {
        background: #1d4ed8;
        color: white;
    }

    .btn-light-stream {
        background: rgba(255,255,255,0.12);
        color: white;
        border: 1px solid rgba(255,255,255,0.18);
    }

    .btn-light-stream:hover {
        background: rgba(255,255,255,0.22);
        color: white;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 20px;
        margin-bottom: 45px;
    }

    .stat-card {
        background: rgba(15, 23, 42, 0.94);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 26px;
        padding: 26px;
        box-shadow: 0 24px 55px rgba(0,0,0,0.36);
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: "";
        position: absolute;
        width: 120px;
        height: 120px;
        border-radius: 999px;
        background: rgba(37, 99, 235, 0.20);
        top: -40px;
        right: -40px;
    }

    .stat-label {
        color: #94a3b8;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        position: relative;
        z-index: 2;
    }

    .stat-value {
        font-size: 42px;
        font-weight: 950;
        color: white;
        position: relative;
        z-index: 2;
    }

    .stat-small {
        color: #cbd5e1;
        margin-top: 6px;
        position: relative;
        z-index: 2;
    }

    .section-title {
        font-size: 28px;
        font-weight: 950;
        margin-bottom: 20px;
    }

    .top-section {
        background: rgba(15, 23, 42, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 30px;
        padding: 28px;
        box-shadow: 0 28px 70px rgba(0,0,0,0.40);
    }

    .movie-row {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 22px;
    }

    .movie-card {
        position: relative;
        min-height: 285px;
        border-radius: 22px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        text-decoration: none;
        color: white;
        display: flex;
        align-items: flex-end;
        box-shadow: 0 20px 45px rgba(0,0,0,0.50);
        border: 1px solid rgba(255,255,255,0.10);
        transition: 0.25s ease;
    }

    .movie-card:hover {
        transform: translateY(-8px) scale(1.02);
        color: white;
        border-color: rgba(96,165,250,0.55);
        box-shadow: 0 25px 60px rgba(37,99,235,0.25);
    }

    .movie-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, rgba(2,6,23,0.98) 0%, rgba(2,6,23,0.58) 45%, rgba(2,6,23,0.12) 100%);
    }

    .movie-info {
        position: relative;
        z-index: 2;
        padding: 16px;
        width: 100%;
    }

    .movie-title {
        font-weight: 950;
        font-size: 17px;
        line-height: 1.2;
        margin-bottom: 7px;
    }

    .movie-meta {
        font-size: 13px;
        color: #cbd5e1;
        margin-bottom: 8px;
    }

    .movie-rating {
        color: #facc15;
        font-size: 14px;
        letter-spacing: 1px;
    }

    .badge-status {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 3;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 900;
        background: rgba(15,23,42,0.78);
        border: 1px solid rgba(255,255,255,0.18);
        backdrop-filter: blur(8px);
    }

    .badge-pendiente {
        color: #fbbf24;
    }

    .badge-vista {
        color: #4ade80;
    }

    .empty-box {
        background: rgba(2, 6, 23, 0.8);
        border: 1px dashed #334155;
        border-radius: 22px;
        padding: 35px;
        text-align: center;
        color: #94a3b8;
    }

    @@media (max-width: 900px) {
        .stats-header h1 {
            font-size: 34px;
        }

        .top-section {
            padding: 22px;
        }
    }
</style>

<div class="stats-page">
    <div class="stats-container">

        <div class="stats-header">
            <div>
                <h1>Estadísticas del catálogo</h1>
                <p>Resumen general de tus series, películas, estados y calificaciones.</p>
            </div>

            <div>
                <a asp-action="Index" class="stream-btn btn-light-stream">Volver al catálogo</a>
                <a asp-action="Registros" class="stream-btn btn-light-stream">Ver registros</a>
                <a asp-action="Create" class="stream-btn btn-primary-stream">Agregar nuevo</a>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total</div>
                <div class="stat-value">@ViewBag.Total</div>
                <div class="stat-small">Registros guardados</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Películas</div>
                <div class="stat-value">@ViewBag.Peliculas</div>
                <div class="stat-small">Contenido tipo película</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Series</div>
                <div class="stat-value">@ViewBag.Series</div>
                <div class="stat-small">Contenido tipo serie</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Vistas</div>
                <div class="stat-value">@ViewBag.Vistas</div>
                <div class="stat-small">Ya terminadas</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Pendientes</div>
                <div class="stat-value">@ViewBag.Pendientes</div>
                <div class="stat-small">Por ver después</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Promedio</div>
                <div class="stat-value">@String.Format("{0:0.0}", ViewBag.Promedio)</div>
                <div class="stat-small">Calificación general</div>
            </div>
        </div>

        <div class="top-section">
            <h2 class="section-title">Top 5 mejor calificadas</h2>

            @if (top5 != null && top5.Any())
            {
                <div class="movie-row">
                    @foreach (var item in top5)
                    {
                        <a asp-action="Details" asp-route-id="@item.Id" class="movie-card" style="background-image: url('@PosterUrl(item)');">
                            <span class="badge-status @(item.Estado == "Vista" ? "badge-vista" : "badge-pendiente")">
                                @item.Estado
                            </span>

                            <div class="movie-info">
                                <div class="movie-title">@item.Titulo</div>
                                <div class="movie-meta">@item.Tipo • @item.Genero • @item.Anio_estreno</div>
                                <div class="movie-rating">@Estrellas(item.Calificacion)</div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">
                    Todavía no hay contenido registrado para mostrar estadísticas.
                </div>
            }
        </div>

    </div>
</div>