@model List<CatalogoWeb.Entities.Contenido>

@{
    ViewData["Title"] = "Catálogo";
    var top5 = ViewBag.Top5 as List<CatalogoWeb.Entities.Contenido>;
    var peliculas = ViewBag.Peliculas as List<CatalogoWeb.Entities.Contenido>;
    var series = ViewBag.Series as List<CatalogoWeb.Entities.Contenido>;
}

@functions {
    string PosterUrl(CatalogoWeb.Entities.Contenido item)
    {
        return $"https://picsum.photos/seed/{Uri.EscapeDataString(item.Titulo + item.Id)}/500/750";
    }

    string FondoUrl(CatalogoWeb.Entities.Contenido item)
    {
        return $"https://picsum.photos/seed/banner{Uri.EscapeDataString(item.Titulo + item.Id)}/1600/700";
    }

    string Estrellas(int calificacion)
    {
        if (calificacion < 1) calificacion = 1;
        if (calificacion > 5) calificacion = 5;

        return new string('★', calificacion) + new string('☆', 5 - calificacion);
    }
}

<style>
    body {
        background: #020617;
        color: #ffffff;
    }

    .main-streaming {
        min-height: 100vh;
        padding-bottom: 50px;
    }

    .hero {
        position: relative;
        min-height: 420px;
        border-radius: 0 0 35px 35px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        margin-bottom: 35px;
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(2,6,23,0.98), rgba(2,6,23,0.75), rgba(2,6,23,0.25)),
                    linear-gradient(0deg, #020617 0%, rgba(2,6,23,0.25) 45%, rgba(2,6,23,0.35) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 80px 40px;
        max-width: 760px;
    }

    .brand-title {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 2px;
        color: #93c5fd;
        margin-bottom: 18px;
    }

    .hero-title {
        font-size: 56px;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 18px;
    }

    .hero-text {
        color: #cbd5e1;
        font-size: 17px;
        max-width: 650px;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .stream-btn {
        border: none;
        border-radius: 999px;
        padding: 11px 22px;
        font-weight: 700;
        text-decoration: none;
        display: inline-block;
    }

    .stream-btn-primary {
        background: #2563eb;
        color: #ffffff;
    }

    .stream-btn-primary:hover {
        background: #1d4ed8;
        color: #ffffff;
    }

    .stream-btn-light {
        background: rgba(255,255,255,0.14);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .stream-btn-light:hover {
        background: rgba(255,255,255,0.22);
        color: #ffffff;
    }

    .filter-panel {
        background: rgba(15, 23, 42, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 24px;
        padding: 22px;
        margin-bottom: 35px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.35);
    }

    .filter-panel input,
    .filter-panel select {
        background: #0f172a;
        color: #ffffff;
        border: 1px solid #334155;
        border-radius: 14px;
        height: 45px;
    }

    .filter-panel input::placeholder {
        color: #94a3b8;
    }

    .filter-panel input:focus,
    .filter-panel select:focus {
        background: #0f172a;
        color: #ffffff;
        border-color: #3b82f6;
        box-shadow: none;
    }

    .section-title {
        font-size: 26px;
        font-weight: 900;
        margin-bottom: 18px;
        margin-top: 20px;
    }

    .movie-row {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
        gap: 20px;
        margin-bottom: 45px;
    }

    .movie-card {
        position: relative;
        height: 270px;
        border-radius: 20px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        text-decoration: none;
        color: #ffffff;
        display: flex;
        align-items: flex-end;
        transform: translateY(0);
        transition: 0.25s ease;
        box-shadow: 0 18px 35px rgba(0,0,0,0.45);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .movie-card:hover {
        transform: translateY(-8px) scale(1.02);
        color: #ffffff;
        box-shadow: 0 25px 55px rgba(37,99,235,0.25);
        border-color: rgba(96,165,250,0.55);
    }

    .movie-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, rgba(2,6,23,0.98) 0%, rgba(2,6,23,0.55) 45%, rgba(2,6,23,0.10) 100%);
    }

    .movie-info {
        position: relative;
        z-index: 2;
        padding: 14px;
        width: 100%;
    }

    .movie-title {
        font-weight: 900;
        font-size: 16px;
        line-height: 1.2;
        margin-bottom: 6px;
    }

    .movie-meta {
        font-size: 12px;
        color: #cbd5e1;
        margin-bottom: 7px;
    }

    .movie-rating {
        color: #facc15;
        font-size: 13px;
        letter-spacing: 1px;
    }

    .badge-status {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 3;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 800;
        background: rgba(15,23,42,0.78);
        border: 1px solid rgba(255,255,255,0.18);
        backdrop-filter: blur(8px);
    }

    .badge-pendiente {
        color: #fbbf24;
    }

    .badge-vista {
        color: #4ade80;
    }

    .empty-box {
        background: rgba(15, 23, 42, 0.9);
        border: 1px dashed #334155;
        border-radius: 20px;
        padding: 30px;
        color: #94a3b8;
        text-align: center;
    }

    .page-container {
        width: min(1380px, 94%);
        margin: auto;
    }
</style>

<div class="main-streaming">

    @{
        var heroItem = top5 != null && top5.Any() ? top5.First() : Model.FirstOrDefault();
    }

    @if (heroItem != null)
    {
        <section class="hero" style="background-image: url('@FondoUrl(heroItem)');">
            <div class="hero-content">
                <div class="brand-title">CINEPHILE</div>
                <h1 class="hero-title">@heroItem.Titulo</h1>
                <p class="hero-text">
                    @heroItem.Resenia
                </p>

                <div class="movie-meta">
                    @heroItem.Tipo • @heroItem.Genero • @heroItem.Anio_estreno • @heroItem.Plataforma
                </div>

                <div class="movie-rating">
                    @Estrellas(heroItem.Calificacion)
                </div>

                <div class="hero-actions">
                    <a asp-action="Details" asp-route-id="@heroItem.Id" class="stream-btn stream-btn-primary">Ver detalle</a>
                    <a asp-action="Create" class="stream-btn stream-btn-light">Agregar nuevo</a>
                    <a asp-action="Registros" class="stream-btn stream-btn-light">Ver todos los registros</a>
                    <a asp-action="Estadisticas" class="stream-btn stream-btn-light">Estadísticas</a>
                </div>
            </div>
        </section>
    }

    <div class="page-container">

        @if (top5 != null && top5.Any())
        {
            <h2 class="section-title">Top 5 mejor calificadas</h2>

            <div class="movie-row">
                @foreach (var item in top5)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="movie-card" style="background-image: url('@PosterUrl(item)');">
                        <span class="badge-status @(item.Estado == "Vista" ? "badge-vista" : "badge-pendiente")">@item.Estado</span>

                        <div class="movie-info">
                            <div class="movie-title">@item.Titulo</div>
                            <div class="movie-meta">@item.Tipo • @item.Anio_estreno</div>
                            <div class="movie-rating">@Estrellas(item.Calificacion)</div>
                        </div>
                    </a>
                }
            </div>
        }

        @if (peliculas != null && peliculas.Any())
        {
            <h2 class="section-title">Películas</h2>

            <div class="movie-row">
                @foreach (var item in peliculas)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="movie-card" style="background-image: url('@PosterUrl(item)');">
                        <span class="badge-status @(item.Estado == "Vista" ? "badge-vista" : "badge-pendiente")">@item.Estado</span>

                        <div class="movie-info">
                            <div class="movie-title">@item.Titulo</div>
                            <div class="movie-meta">@item.Genero • @item.Anio_estreno</div>
                            <div class="movie-rating">@Estrellas(item.Calificacion)</div>
                        </div>
                    </a>
                }
            </div>
        }

        @if (series != null && series.Any())
        {
            <h2 class="section-title">Series</h2>

            <div class="movie-row">
                @foreach (var item in series)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="movie-card" style="background-image: url('@PosterUrl(item)');">
                        <span class="badge-status @(item.Estado == "Vista" ? "badge-vista" : "badge-pendiente")">@item.Estado</span>

                        <div class="movie-info">
                            <div class="movie-title">@item.Titulo</div>
                            <div class="movie-meta">@item.Genero • @item.Anio_estreno</div>
                            <div class="movie-rating">@Estrellas(item.Calificacion)</div>
                        </div>
                    </a>
                }
            </div>
        }

        @if (!Model.Any())
        {
            <div class="empty-box">
                No se encontraron registros con los filtros seleccionados.
            </div>
        }

    </div>
</div>